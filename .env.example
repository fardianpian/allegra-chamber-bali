# Form handler (Web3Forms or Formspree). Exposed at build time, must be PUBLIC_*
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Site
PUBLIC_SITE_URL=https://allegra.indonesiaistimewastudio.id
PUBLIC_WHATSAPP_NUMBER=62XXXXXXXXXXX
PUBLIC_CONTACT_EMAIL=allegrachamberbali@gmail.com
PUBLIC_INSTAGRAM=https://instagram.com/your-handle

# Analytics (optional)
PUBLIC_PLAUSIBLE_DOMAIN=allegra.indonesiaistimewastudio.id
# PUBLIC_GA4_ID=G-XXXXXXX

# Cloudflare Workers AI — used by scripts/generate-cover-image.mjs (build-time only,
# never called at runtime — the site stays static per CLAUDE.md rule #7).
# Token needs "Workers AI - Read" permission, scoped to this account.
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-workers-ai-api-token
