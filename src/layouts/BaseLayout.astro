---
import '@fontsource/cormorant-garamond/500.css'
import '@fontsource/cormorant-garamond/600.css'
import '@fontsource/cormorant-garamond/500-italic.css'
import '@fontsource/inter/400.css'
import '@fontsource/inter/500.css'
import '@fontsource/inter/600.css'
import '../styles/global.css'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import { site, withTrailingSlash } from '../lib/site'
import type { Lang } from '../i18n/languages'

interface Props {
	lang: Lang
	title: string
	description: string
	path: string
	jsonLd?: Record<string, unknown> | Record<string, unknown>[]
	ogImage?: string
	/** Skip canonical/hreflang and emit `noindex` — for error pages with no real bilingual pair. */
	noindex?: boolean
}

const { lang, title, description, path, jsonLd, ogImage, noindex = false } = Astro.props

const enPath = withTrailingSlash(path.replace(/^\/id(\/|$)/, '/'))
const idPath = enPath === '/' ? '/id/' : `/id${enPath}`
const canonical = new URL(lang === 'id' ? idPath : enPath, site.url).toString()
const ogImageUrl = ogImage
	? new URL(ogImage, site.url).toString()
	: new URL('/images/og-cliffside-uluwatu.jpg', site.url).toString()
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />

		<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${site.ga4Id}`}></script>
		<script
			is:inline
			set:html={`window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', '${site.ga4Id}');`}
		/>
		{
			noindex ? (
				<meta name="robots" content="noindex, follow" />
			) : (
				<>
					<link rel="canonical" href={canonical} />
					<link rel="alternate" hreflang="en" href={new URL(enPath, site.url).toString()} />
					<link rel="alternate" hreflang="id" href={new URL(idPath, site.url).toString()} />
					<link rel="alternate" hreflang="x-default" href={new URL(enPath, site.url).toString()} />
				</>
			)
		}

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={lang === 'id' ? 'id_ID' : 'en_US'} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		{jsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}
	</head>
	<body>
		<a href="#main" class="skip-link">Skip to content</a>
		<Header lang={lang} path={path} />
		<main id="main">
			<slot />
		</main>
		<Footer lang={lang} />
		<script>
			const els = document.querySelectorAll('.reveal')
			const io = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible')
							io.unobserve(entry.target)
						}
					}
				},
				{ rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
			)
			els.forEach((el) => io.observe(el))
		</script>
	</body>
</html>
