---
import Button from '../ui/Button.astro'
import { waLink } from '../../lib/site'

interface Props {
	message: string
	label: string
	variant?: 'primary' | 'gold' | 'outline' | 'ghost'
	class?: string
}
const { message, label, variant = 'primary', class: className = '' } = Astro.props
---

<Button href={waLink(message)} target="_blank" variant={variant} class={className}>
	<svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
		<path
			d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.2-.6.8-.8 1-.1.2-.3.2-.5.1-1.3-.6-2.2-1.1-3.1-2.5-.2-.3 0-.5.2-.7.2-.2.5-.5.6-.7.1-.2.1-.4 0-.6-.1-.2-.6-1.5-.8-2-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-1 1-.9 2.3.1 1.6 1.2 3.1 1.4 3.3.2.2 1.9 2.9 4.6 3.9 2.3.9 2.3.6 2.7.6.4 0 1.3-.5 1.5-1 .2-.5.2-1 .1-1.1-.1-.1-.3-.2-.5-.3Z"
		></path>
	</svg>
	{label}
</Button>
