---
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'
import { site } from '../../lib/site'
import Logo from '../ui/Logo.astro'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const nav = t('nav')
const footer = t('footer')
const prefix = lang === 'en' ? '' : '/id'
const home = lang === 'en' ? '/' : '/id/'
const year = new Date().getFullYear()

const links = [
	{ href: `${prefix}/repertoire/`, label: nav.repertoire },
	{ href: `${prefix}/packages/`, label: nav.packages },
	{ href: `${prefix}/gallery/`, label: nav.gallery },
	{ href: `${prefix}/about/`, label: nav.about },
	{ href: `${prefix}/for-planners/`, label: nav.forPlanners },
	{ href: `${prefix}/faq/`, label: nav.faq },
	{ href: `${prefix}/contact/`, label: nav.contact },
]
---

<footer class="bg-ink text-ivory">
	<div class="container-max grid gap-12 py-16 md:grid-cols-[1.4fr_1fr_1fr]">
		<div>
			<a href={home}><Logo size="md" tone="ivory" /></a>
			<p class="mt-3 max-w-sm text-ivory/70">{footer.tagline}</p>
			<p class="mt-6 text-xs uppercase tracking-[0.14em] text-ivory/50">{footer.studioLine}</p>
		</div>

		<div>
			<p class="eyebrow text-ivory/50">{footer.quickLinks}</p>
			<ul class="mt-2">
				{
					links.map((link) => (
						<li>
							<a href={link.href} class="block py-2 text-sm text-ivory/80 hover:text-gold">
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>

		<div>
			<p class="eyebrow text-ivory/50">{footer.contact}</p>
			<ul class="mt-2 text-sm text-ivory/80">
				<li>
					<a href={`mailto:${site.contactEmail}`} class="block py-2 hover:text-gold">{site.contactEmail}</a>
				</li>
				<li>
					<a
						href={site.instagram}
						target="_blank"
						rel="noopener noreferrer"
						class="block py-2 hover:text-gold">Instagram</a
					>
				</li>
			</ul>
		</div>
	</div>

	<div
		class="container-max flex flex-col gap-2 border-t border-ivory/10 py-6 text-xs text-ivory/50 md:flex-row md:justify-between"
	>
		<p>&copy; {year} Allegra Chamber Bali. {footer.rights}</p>
		<a href={`${prefix}/privacy/`} class="hover:text-gold">{footer.privacyLink}</a>
	</div>
</footer>
