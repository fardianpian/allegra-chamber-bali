---
interface Props {
	href: string
	variant?: 'primary' | 'gold' | 'outline' | 'ghost'
	class?: string
	target?: '_blank'
}
const { href, variant = 'primary', class: className = '', target } = Astro.props

const base =
	'inline-flex items-center justify-center gap-2 px-7 py-3.5 text-sm tracking-[0.08em] uppercase transition-colors duration-300'
const variants = {
	primary: 'bg-ink text-ivory hover:bg-gold hover:text-ink',
	gold: 'bg-gold text-ink hover:bg-ivory',
	outline: 'border border-ink text-ink hover:bg-ink hover:text-ivory',
	ghost: 'border border-ivory text-ivory hover:bg-ivory hover:text-ink',
}
---

<a
	href={href}
	target={target}
	rel={target === '_blank' ? 'noopener noreferrer' : undefined}
	class:list={[base, variants[variant], className]}
>
	<slot />
</a>
