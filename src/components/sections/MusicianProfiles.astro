---
import { Image } from 'astro:assets'
import SectionHeading from '../ui/SectionHeading.astro'
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'
import fardian from '../../assets/about/fardian.jpg'
import yessica from '../../assets/about/yessica.jpg'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const about = t('aboutPage')

const photos = { fardian, yessica } as const
---

<section class="section bg-ivory pt-0">
	<div class="container-max">
		<SectionHeading
			align="center"
			heading={about.team.heading}
			subhead={about.team.subhead}
			class="text-center"
		/>

		<div class="mx-auto mt-12 grid max-w-2xl gap-8 sm:grid-cols-2">
			{
				about.team.members.map((member, i) => (
					<div class="reveal text-center" style={`transition-delay: ${i * 60}ms`}>
						<Image
							src={photos[member.person]}
							alt=""
							width={480}
							height={480}
							format="avif"
							quality={70}
							loading="lazy"
							class="mx-auto aspect-square w-full max-w-xs object-cover"
						/>
						<p class="mt-4 font-display text-lg">{member.name}</p>
						<p class="mt-1 text-sm text-taupe">{member.role}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
