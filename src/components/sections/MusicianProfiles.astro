---
import SectionHeading from '../ui/SectionHeading.astro'
import Placeholder from '../ui/Placeholder.astro'
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const about = t('aboutPage')

// No real musician names/photos/bios confirmed yet (CLAUDE.md §9) — fixed count of
// placeholder cards until the owner provides real ones.
const placeholderCount = 4
---

<section class="section bg-ivory pt-0">
	<div class="container-max">
		<SectionHeading
			align="center"
			heading={about.musiciansHeading}
			subhead={about.musiciansSubhead}
			class="text-center"
		/>

		<div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
			{
				Array.from({ length: placeholderCount }).map((_, i) => (
					<div class="reveal text-center" style={`transition-delay: ${i * 60}ms`}>
						<Placeholder ratio="1/1" class="mx-auto" label="" />
						<p class="mt-4 font-display text-lg">TODO — Musician Name</p>
						<p class="mt-1 text-sm text-taupe">TODO: instrument, training, experience</p>
					</div>
				))
			}
		</div>

		<p class="reveal mt-8 text-center text-xs text-taupe">{about.musiciansNote}</p>
	</div>
</section>
