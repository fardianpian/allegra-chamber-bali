---
import Eyebrow from '../ui/Eyebrow.astro'
import Button from '../ui/Button.astro'
import WhatsAppCTA from '../media/WhatsAppCTA.astro'
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const finalCta = t('finalCta')
const whatsappMessage = t('whatsappMessage')
const contactHref = lang === 'en' ? '/contact/' : '/id/contact/'
---

<section class="section bg-ink text-ivory">
	<div class="container-max reveal flex flex-col items-center text-center">
		<Eyebrow class="text-ivory/70">{finalCta.eyebrow}</Eyebrow>
		<h2 class="mt-3 max-w-2xl text-4xl md:text-5xl">{finalCta.heading}</h2>
		<p class="mt-4 max-w-xl text-ivory/75">{finalCta.subhead}</p>
		<div class="mt-8 flex flex-wrap justify-center gap-4">
			<WhatsAppCTA message={whatsappMessage} label={finalCta.ctaPrimary} variant="gold" />
			<Button href={contactHref} variant="ghost">{finalCta.ctaSecondary}</Button>
		</div>
	</div>
</section>
