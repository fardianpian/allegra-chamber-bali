---
import { Image } from 'astro:assets'
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'
import piano2 from '../../assets/gallery/piano-garden-reception-night.jpg'
import ensemblePortrait from '../../assets/gallery/string-ensemble-musicians-wedding-bali.jpg'
import pianistBeach from '../../assets/gallery/wedding-pianist-beachfront-sunset-bali.png'
import grandPianoCliffside from '../../assets/gallery/grand-piano-cliffside-wedding-ceremony-bali.png'
import pianistGardenPathway from '../../assets/gallery/wedding-pianist-garden-pathway-sunset-bali.png'
import quartetGarden from '../../assets/gallery/string-quartet-garden-ceremony-bali.jpg'
import receptionSetup from '../../assets/gallery/wedding-reception-setup-string-lights-bali.jpg'
import quartetCello from '../../assets/gallery/string-quartet-cello-garden-ceremony-bali.jpg'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const gallery = t('galleryPage')

// Filter tags kept for all venue types the owner books, even ones without a photo yet —
// clicking an empty tag shows the "no photos yet" message until new documentation comes in.
const types = ['cliffside', 'beach', 'garden', 'chapel', 'ballroom'] as const
// Real event photos so far (owner-supplied, 2026-06-18 + 2026-06-24 batches, plus the Solo
// package photo). Add more tiles here (with the matching `type`) as the owner confirms new
// event photography (CLAUDE.md §9).
const tiles = [
	{ type: 'garden', src: piano2, alt: 'Garden reception with live wedding pianist, Bali' },
	{
		type: 'garden',
		src: ensemblePortrait,
		alt: 'Allegra Chamber Bali string ensemble musicians at a garden wedding venue in Bali',
	},
	{ type: 'beach', src: pianistBeach, alt: 'Wedding pianist performing beachfront at sunset in Bali' },
	{
		type: 'cliffside',
		src: grandPianoCliffside,
		alt: 'Grand piano set up for a cliffside wedding ceremony in Bali at sunset',
	},
	{
		type: 'garden',
		src: pianistGardenPathway,
		alt: 'Wedding pianist performing in a garden pathway at sunset in Bali',
	},
	{
		type: 'garden',
		src: quartetGarden,
		alt: 'Live string quartet performing at a garden wedding ceremony in Bali',
	},
	{
		type: 'garden',
		src: receptionSetup,
		alt: 'Wedding reception setup with string lights and floral decor in Bali',
	},
	{ type: 'garden', src: quartetCello, alt: 'String quartet with cello performing at a Bali garden wedding' },
] as const

const filterBtnBase =
	'filter-btn px-4 py-3.5 text-xs uppercase tracking-[0.1em] border border-ink/20 text-ink/70 transition-colors hover:border-gold hover:text-ink data-[active=true]:bg-ink data-[active=true]:text-ivory data-[active=true]:border-ink'
---

<section class="section bg-ivory pt-0">
	<div class="container-max">
		<div class="reveal flex flex-wrap gap-2" data-filter-group="type">
			<button
				type="button"
				class={filterBtnBase}
				data-filter-value="all"
				data-active="true"
				aria-pressed="true"
			>
				{gallery.filterAll}
			</button>
			{
				types.map((type) => (
					<button
						type="button"
						class={filterBtnBase}
						data-filter-value={type}
						data-active="false"
						aria-pressed="false"
					>
						{gallery.typeLabels[type]}
					</button>
				))
			}
		</div>

		<div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4" id="gallery-grid">
			{
				tiles.map((tile) => (
					<div class="gallery-tile reveal" data-type={tile.type}>
						<Image
							src={tile.src}
							alt={tile.alt}
							width={800}
							height={1000}
							format="avif"
							quality={70}
							loading="lazy"
							class="aspect-[4/5] w-full object-cover"
						/>
					</div>
				))
			}
		</div>
		<p class="reveal mt-6 text-center text-sm text-taupe" id="no-results" hidden aria-live="polite">
			{gallery.noResults}
		</p>
	</div>
</section>

<script>
	const group = document.querySelector<HTMLElement>('[data-filter-group="type"]')
	const tiles = document.querySelectorAll<HTMLElement>('.gallery-tile')
	const noResults = document.getElementById('no-results')

	group?.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const value = btn.dataset.filterValue || 'all'
			group.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((b) => {
				const isActive = b === btn
				b.dataset.active = String(isActive)
				b.setAttribute('aria-pressed', String(isActive))
			})

			let visibleCount = 0
			tiles.forEach((tile) => {
				const visible = value === 'all' || tile.dataset.type === value
				tile.hidden = !visible
				if (visible) visibleCount++
			})
			if (noResults) noResults.hidden = visibleCount > 0
		})
	})
</script>
