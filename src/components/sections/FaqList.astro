---
// Native <details>/<summary> accordion — no JS needed, accessible by default.
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const faq = t('faqPage')
---

<section class="section bg-ivory pt-0">
	<div class="container-max">
		<div class="reveal mx-auto max-w-2xl divide-y divide-ink/10 border-y border-ink/10">
			{
				faq.items.map((item) => (
					<details class="group py-5">
						<summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg text-ink marker:content-none">
							<span class="font-medium">{item.question}</span>
							<span
								aria-hidden="true"
								class="shrink-0 text-xl text-gold transition-transform duration-200 group-open:rotate-45"
							>
								+
							</span>
						</summary>
						<p class="mt-3 text-ink/75">{item.answer}</p>
					</details>
				))
			}
		</div>
	</div>
</section>
