---
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import WhatsAppCTA from '../media/WhatsAppCTA.astro'
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const pkg = t('packagesPage')

const all = await getCollection('packages')
const items = all.sort((a, b) => a.data.order - b.data.order)
const rendered = await Promise.all(
	items.map(async (item) => ({ item, Content: (await render(item)).Content })),
)
---

<section class="section bg-ivory pt-0">
	<div class="container-max flex flex-col gap-14">
		{
			rendered.map(({ item, Content }, i) => (
				<article
					id={item.data.formation}
					class="reveal scroll-mt-28 border-t border-ink/10 pt-10 md:grid md:grid-cols-[1fr_1.4fr] md:gap-12"
					style={`transition-delay: ${i * 60}ms`}
				>
					<div>
						<p class="eyebrow">{String(i + 1).padStart(2, '0')}</p>
						<h2 class="mt-2 text-3xl md:text-4xl">{item.data.name}</h2>
						<p class="mt-3 text-taupe">{item.data.summary}</p>
					</div>

					<div class="mt-6 md:mt-0">
						{item.data.image && (
							<Image
								src={item.data.image}
								alt={item.data.imageAlt || item.data.name}
								width={960}
								height={640}
								loading="lazy"
								class="mb-6 aspect-[3/2] w-full object-cover"
							/>
						)}

						<div class="leading-relaxed text-ink/85">
							<Content />
						</div>

						<dl class="mt-6 grid gap-4 sm:grid-cols-2">
							<div>
								<dt class="eyebrow">{pkg.idealForLabel}</dt>
								<dd class="mt-1 text-sm text-ink/80">{item.data.idealFor.join(' · ')}</dd>
							</div>
							<div>
								<dt class="eyebrow">{pkg.setLengthLabel}</dt>
								<dd class="mt-1 text-sm text-ink/80">{item.data.setLength || pkg.setLengthTbd}</dd>
							</div>
						</dl>

						<WhatsAppCTA
							message={`Hi Allegra Chamber Bali, I'd like to inquire about the ${item.data.name} package for my wedding.`}
							label={pkg.ctaInquire}
							variant="outline"
							class="mt-7"
						/>
					</div>
				</article>
			))
		}
	</div>

	<div class="container-max">
		<p class="reveal mt-12 border-t border-ink/10 pt-6 text-xs text-taupe">{pkg.pricingNote}</p>
	</div>
</section>
