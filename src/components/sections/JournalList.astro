---
import { getCollection } from 'astro:content'
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const journal = t('journalPage')
const prefix = lang === 'en' ? '' : '/id'

const pillars = ['planning', 'piano-repertoire', 'bali-venues', 'for-planners'] as const

const all = await getCollection('articles', ({ data }) => !data.draft)
const enArticles = all.filter((a) => !a.slug.startsWith('id/'))
const idTranslations = new Map(
	all.filter((a) => a.slug.startsWith('id/')).map((a) => [a.slug.replace(/^id\//, ''), a]),
)

// On the ID listing, show the genuine translation's heading/excerpt/pillar when one exists
// (src/content/articles/id/<slug>.md); otherwise fall back to the EN entry.
const articles = enArticles
	.map((enArticle) => {
		const translated = lang === 'id' ? idTranslations.get(enArticle.slug) : undefined
		return { slug: enArticle.slug, data: (translated ?? enArticle).data }
	})
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const dateFormatter = new Intl.DateTimeFormat(lang === 'en' ? 'en-US' : 'id-ID', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
})

const filterBtnBase =
	'filter-btn px-4 py-2 text-xs uppercase tracking-[0.1em] border border-ink/20 text-ink/70 transition-colors hover:border-gold hover:text-ink data-[active=true]:bg-ink data-[active=true]:text-ivory data-[active=true]:border-ink'
---

<section class="section bg-ivory pt-0">
	<div class="container-max">
		<div class="reveal flex flex-wrap gap-2" data-filter-group="pillar">
			<button type="button" class={filterBtnBase} data-filter-value="all" data-active="true">
				{journal.filterAll}
			</button>
			{
				pillars.map((p) => (
					<button type="button" class={filterBtnBase} data-filter-value={p} data-active="false">
						{journal.pillarLabels[p]}
					</button>
				))
			}
		</div>

		<div class="reveal mx-auto mt-10 grid max-w-5xl gap-10 sm:grid-cols-2" id="article-list">
			{
				articles.map((article) => (
					<a
						href={`${prefix}/journal/${article.slug}/`}
						class="article-card group flex flex-col border-t border-ink/10 pt-6"
						data-pillar={article.data.pillar}
					>
						{article.data.ogImage && (
							<img
								src={article.data.ogImage}
								alt=""
								width="1200"
								height="630"
								loading="lazy"
								decoding="async"
								class="aspect-[1200/630] w-full rounded-sm object-cover"
							/>
						)}
						<p class="eyebrow mt-4 text-taupe">{journal.pillarLabels[article.data.pillar]}</p>
						<h2 class="mt-2 text-2xl transition-colors group-hover:text-gold">{article.data.heading}</h2>
						<p class="mt-3 text-ink/80">{article.data.excerpt}</p>
						<p class="mt-4 text-xs uppercase tracking-[0.1em] text-taupe">
							{dateFormatter.format(article.data.pubDate)}
						</p>
					</a>
				))
			}
		</div>
		<p class="reveal mx-auto mt-6 max-w-2xl text-center text-sm text-taupe" id="no-results" hidden>
			{journal.noResults}
		</p>
	</div>
</section>

<script>
	const group = document.querySelector<HTMLElement>('[data-filter-group="pillar"]')
	const cards = document.querySelectorAll<HTMLElement>('.article-card')
	const noResults = document.getElementById('no-results')

	function applyFilter(value: string) {
		let visibleCount = 0
		cards.forEach((card) => {
			const visible = value === 'all' || card.dataset.pillar === value
			card.hidden = !visible
			if (visible) visibleCount++
		})
		if (noResults) noResults.hidden = visibleCount > 0
	}

	group?.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			group.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((b) => {
				b.dataset.active = String(b === btn)
			})
			applyFilter(btn.dataset.filterValue || 'all')
		})
	})
</script>
