---
import { getCollection } from 'astro:content'
import Eyebrow from '../ui/Eyebrow.astro'
import { useTranslations } from '../../i18n/utils'
import type { Lang } from '../../i18n/languages'

interface Props {
	lang: Lang
}
const { lang } = Astro.props
const t = useTranslations(lang)
const trust = t('trust')
const venues = await getCollection('venues')
const venueNames = venues.map((v) => v.data.name)
---

<section class="reveal border-y border-ink/10 bg-ivory py-10">
	<div class="container-max text-center">
		<Eyebrow>{trust.eyebrow}</Eyebrow>
		<p class="mt-3 text-sm tracking-wide text-ink/70">
			{trust.heading}
			<span class="text-ink">{venueNames.join(' · ')}</span>
		</p>
		<p class="mt-1 text-xs text-taupe">{trust.note}</p>
	</div>
</section>
