---
// Lightweight header for inner pages (no full-bleed photo, unlike the homepage Hero).
import SectionHeading from '../ui/SectionHeading.astro'

interface Props {
	eyebrow?: string
	heading: string
	subhead?: string
}
const { eyebrow, heading, subhead } = Astro.props
---

<section class="section bg-ivory pb-10 pt-32 md:pt-40">
	<div class="container-max">
		<SectionHeading
			level="h1"
			align="center"
			eyebrow={eyebrow}
			heading={heading}
			subhead={subhead}
			class="text-center"
		/>
	</div>
</section>
