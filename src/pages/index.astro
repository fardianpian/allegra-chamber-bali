---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/sections/Hero.astro'
// import TrustStrip from '../components/sections/TrustStrip.astro' // hidden until real partner logos are available
import Formations from '../components/sections/Formations.astro'
import FeaturedVideo from '../components/sections/FeaturedVideo.astro'
import FeaturedAudio from '../components/sections/FeaturedAudio.astro'
import Moments from '../components/sections/Moments.astro'
import HowBookingWorks from '../components/sections/HowBookingWorks.astro'
// import Testimonials from '../components/sections/Testimonials.astro' // TODO: re-enable once real testimonials are in
import GalleryPreview from '../components/sections/GalleryPreview.astro'
import ForPlannersStrip from '../components/sections/ForPlannersStrip.astro'
import FinalCTA from '../components/sections/FinalCTA.astro'
import { useTranslations } from '../i18n/utils'
import { getHomeJsonLd, getVideoJsonLd } from '../lib/jsonld'

const lang = 'en'
const t = useTranslations(lang)
const meta = t('meta')
const featuredVideo = t('featuredVideo')

const videoJsonLd = getVideoJsonLd(lang, {
	videoId: '_xuQy2_Uh44',
	name: featuredVideo.heading,
	description: featuredVideo.subhead,
	uploadDate: '2026-06-24',
})
---

<BaseLayout
	lang={lang}
	title={meta.title}
	description={meta.description}
	path="/"
	jsonLd={[...getHomeJsonLd(lang), videoJsonLd]}
>
	<Hero lang={lang} />
	{/* <TrustStrip lang={lang} /> */}
	<Formations lang={lang} />
	<FeaturedVideo lang={lang} />
	<FeaturedAudio lang={lang} />
	<Moments lang={lang} />
	<HowBookingWorks lang={lang} />
	{/* Testimonials hidden until real, permission-cleared quotes are available */}
	<GalleryPreview lang={lang} />
	<ForPlannersStrip lang={lang} />
	<FinalCTA lang={lang} />
</BaseLayout>
