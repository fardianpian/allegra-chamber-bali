---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHeader from '../../components/sections/PageHeader.astro'
import RepertoireList from '../../components/sections/RepertoireList.astro'
import { useTranslations } from '../../i18n/utils'
import { getBreadcrumbJsonLd } from '../../lib/jsonld'

const lang = 'en'
const t = useTranslations(lang)
const repertoire = t('repertoirePage')
const nav = t('nav')
---

<BaseLayout
	lang={lang}
	title={repertoire.title}
	description={repertoire.description}
	path="/repertoire"
	jsonLd={getBreadcrumbJsonLd(lang, [{ name: nav.repertoire, path: '/repertoire' }])}
>
	<PageHeader eyebrow={repertoire.eyebrow} heading={repertoire.heading} subhead={repertoire.subhead} />
	<RepertoireList lang={lang} />
</BaseLayout>
