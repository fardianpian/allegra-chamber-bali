---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import PageHeader from '../../../components/sections/PageHeader.astro'
import PrivacyContent from '../../../components/sections/PrivacyContent.astro'
import { useTranslations } from '../../../i18n/utils'
import { getBreadcrumbJsonLd } from '../../../lib/jsonld'

const lang = 'id'
const t = useTranslations(lang)
const privacy = t('privacyPage')
---

<BaseLayout
	lang={lang}
	title={privacy.title}
	description={privacy.description}
	path="/id/privacy"
	jsonLd={getBreadcrumbJsonLd(lang, [{ name: privacy.heading, path: '/id/privacy' }])}
>
	<PageHeader eyebrow={privacy.eyebrow} heading={privacy.heading} subhead={privacy.subhead} />
	<PrivacyContent lang={lang} />
</BaseLayout>
