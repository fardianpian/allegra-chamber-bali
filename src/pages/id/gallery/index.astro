---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import PageHeader from '../../../components/sections/PageHeader.astro'
import GalleryGrid from '../../../components/sections/GalleryGrid.astro'
import { useTranslations } from '../../../i18n/utils'
import { getBreadcrumbJsonLd } from '../../../lib/jsonld'

const lang = 'id'
const t = useTranslations(lang)
const gallery = t('galleryPage')
const nav = t('nav')
---

<BaseLayout
	lang={lang}
	title={`${gallery.heading} — Allegra Chamber Bali`}
	description={gallery.subhead}
	path="/id/gallery"
	jsonLd={getBreadcrumbJsonLd(lang, [{ name: nav.gallery, path: '/id/gallery' }])}
>
	<PageHeader eyebrow={gallery.eyebrow} heading={gallery.heading} subhead={gallery.subhead} />
	<GalleryGrid lang={lang} />
</BaseLayout>
