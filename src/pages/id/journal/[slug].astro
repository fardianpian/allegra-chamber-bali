---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Button from '../../../components/ui/Button.astro'
import FaqAccordion from '../../../components/ui/FaqAccordion.astro'
import WhatsAppCTA from '../../../components/media/WhatsAppCTA.astro'
import { useTranslations } from '../../../i18n/utils'
import { getBreadcrumbJsonLd, getArticleJsonLd, getFaqJsonLd } from '../../../lib/jsonld'

export async function getStaticPaths() {
	const articles = await getCollection('articles', ({ data }) => !data.draft)
	return articles.map((article) => ({ params: { slug: article.slug }, props: { article } }))
}

const lang = 'id'
const { article } = Astro.props
const { Content } = await render(article)
const t = useTranslations(lang)
const journal = t('journalPage')
const nav = t('nav')
const path = `/id/journal/${article.slug}`

const dateFormatter = new Intl.DateTimeFormat('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })

const jsonLd = [
	getBreadcrumbJsonLd(lang, [
		{ name: nav.journal, path: '/id/journal' },
		{ name: article.data.heading, path },
	]),
	getArticleJsonLd(lang, { ...article.data, title: article.data.heading, path }),
	...(article.data.faq?.length ? [getFaqJsonLd(article.data.faq)] : []),
]
---

<BaseLayout
	lang={lang}
	title={article.data.title}
	description={article.data.description}
	path={path}
	ogImage={article.data.ogImage}
	jsonLd={jsonLd}
	noindex
>
	<article class="section bg-ivory pt-32 md:pt-40">
		<div class="container-max max-w-2xl">
			<a href="/id/journal/" class="reveal text-xs uppercase tracking-[0.1em] text-taupe hover:text-gold">
				{journal.backToJournal}
			</a>
			<p class="reveal eyebrow mt-6 text-taupe">{journal.pillarLabels[article.data.pillar]}</p>
			<h1 class="reveal mt-2 text-4xl md:text-5xl">{article.data.heading}</h1>
			<p class="reveal mt-4 text-xs uppercase tracking-[0.1em] text-taupe">
				{journal.publishedLabel}
				{dateFormatter.format(article.data.pubDate)}
				{
					article.data.updatedDate && (
						<>
							{' '}
							· {journal.updatedLabel} {dateFormatter.format(article.data.updatedDate)}
						</>
					)
				}
			</p>

			<div class="reveal prose-article mt-10 leading-relaxed text-ink/85">
				<Content />
			</div>

			{
				article.data.faq?.length ? (
					<div class="reveal mt-14 border-t border-ink/10 pt-10">
						<h2 class="text-center text-2xl">{journal.faqHeading}</h2>
						<div class="mt-6">
							<FaqAccordion items={article.data.faq} />
						</div>
					</div>
				) : null
			}

			<div class="reveal mt-14 flex flex-col items-start gap-4 border-t border-ink/10 pt-10">
				<h2 class="text-xl">{journal.ctaHeading}</h2>
				<p class="text-ink/80">{journal.ctaNote}</p>
				<WhatsAppCTA
					message={`Hi Allegra Chamber Bali, saya baca "${article.data.heading}" dan ingin bertanya soal booking.`}
					label={nav.checkDate}
					variant="primary"
				/>
				<Button href="/id/packages/" variant="outline">{nav.packages}</Button>
			</div>
		</div>
	</article>
</BaseLayout>
